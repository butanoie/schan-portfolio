# Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit actual values to source control

# Example: API Keys (add your actual keys to .env.local)
# NEXT_PUBLIC_API_KEY=your_api_key_here

# Example: Analytics (add your actual IDs to .env.local)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Simulated loading delay for debugging skeleton visibility (in milliseconds)
# Default: 5000 (5 seconds) for development to see skeleton animations
# Set to 0 for production for instant loading
# Automatically set to 0 in tests and server-side rendering
# NEXT_PUBLIC_LOAD_DELAY=5000

# PostHog Web Analytics (Phase 7)
# Get your project API key from https://posthog.com → Project Settings → Project API Key
# NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking (Phase 7.3)
# Create a project at https://sentry.io → Settings → Projects
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_ENVIRONMENT=production  # Optional: overrides NODE_ENV for Sentry environment tag

# Add your environment variables below as needed
